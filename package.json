{
  "name": "sat-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Plataforma SAT - Gestión de Instalaciones y Servicio Técnico de Motores",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web": "yarn workspace @sat/web dev",
    "mobile": "yarn workspace @sat/mobile start",
    "build:web": "yarn workspace @sat/web build",
    "lint": "yarn workspaces run lint",
    "type-check": "yarn workspaces run type-check",
    "db:migrate": "supabase db push",
    "db:seed": "supabase db reset",
    "db:types": "supabase gen types typescript --local > packages/supabase-client/src/database.types.ts"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.12.7",
    "prettier": "^3.2.5",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=1.22.0"
  }
}
